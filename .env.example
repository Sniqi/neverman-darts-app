# .env.example — copy to .env.local (gitignored) and fill in values for local development.
# .env.local is already excluded by the .gitignore rule ".env.*" / "!.env.example".

# Google Cast Application ID — assigned by the Cast Developer Console after registering
# an unpublished Custom Receiver. See docs/CAST-SETUP.md for the one-time setup steps.
# In GitHub Actions this is supplied as a repo VARIABLE (not a secret):
#   Settings → Secrets and variables → Actions → Variables → VITE_CAST_APP_ID
# The App ID ships in the client bundle and is not a secret (D-09/SETUP-02).
VITE_CAST_APP_ID=
